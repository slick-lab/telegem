            </div>
        </div>
    </footer>

    <script>
    // Add the same interactive features as other pages
    document.querySelectorAll('a[href^="#"]').forEach(anchor => {
        anchor.addEventListener('click', function (e) {
            e.preventDefault();
            const targetId = this.getAttribute('href');
            if (targetId === '#') return;
            
            const targetElement = document.querySelector(targetId);
            if (targetElement) {
                window.scrollTo({
                    top: targetElement.offsetTop - 100,
                    behavior: 'smooth'
                });
            }
        });
    });
    
    // Add copy buttons to code blocks
    document.querySelectorAll('pre code').forEach(codeBlock => {
        const pre = codeBlock.parentElement;
        const button = document.createElement('button');
        button.innerHTML = '📋';
        button.style.cssText = 'position:absolute;top:1rem;right:1rem;background:rgba(99,102,241,0.2);border:1px solid rgba(99,102,241,0.3);color:white;padding:0.25rem 0.5rem;border-radius:var(--radius-sm);cursor:pointer;font-size:0.875rem;transition:all 0.2s ease;';
        button.addEventListener('mouseenter', () => {
            button.style.background = 'rgba(99,102,241,0.3)';
        });
        button.addEventListener('mouseleave', () => {
            button.style.background = 'rgba(99,102,241,0.2)';
        });
        button.addEventListener('click', () => {
            const code = codeBlock.textContent;
            navigator.clipboard.writeText(code).then(() => {
                const originalText = button.innerHTML;
                button.innerHTML = '✅ Copied!';
                setTimeout(() => {
                    button.innerHTML = originalText;
                }, 2000);
            });
        });
        pre.style.position = 'relative';
        pre.appendChild(button);
    });
    </script>
