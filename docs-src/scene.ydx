🔧 SCENE UTILITIES

13). Scene Middleware

-code(

Add middleware to all scenes

bot.use do |ctx, next_middleware|
if ctx.current_scene
# Log scene activity
ctx.logger.info("Scene: #{ctx.current_scene.id}, Step: #{ctx.current_scene.current_step(ctx)}")

```
# Add timeout checking
if ctx.scene_data[:timeout] && Time.now > ctx.scene_data[:timeout]
  ctx.reply("Session expired!")
  ctx.leave_scene
  return
end
```

end

next_middleware.call(ctx)
end
)

14). Scene Helpers

-code(

Check if user is in a scene

if ctx.current_scene
ctx.reply("You're in the #{ctx.current_scene.id} scene")
else
ctx.reply("You're not in a scene")
end

Force exit scene

ctx.leave_scene

Get all defined scenes

scenes = bot.scenes

{ :onboarding => #<Scene>, :quiz => #<Scene> }

Check if scene exists

if bot.scenes[:auth]
ctx.enter_scene(:auth)
else
ctx.reply("Auth scene not available")
end
)

