🔄 STEP TRANSITIONS

9). Moving Between Steps

-code(
bot.scene(:shopping) do
step :browse do |ctx|
ctx.reply("Browse products:")
ctx.reply("1) Phone\n2) Laptop\n3) Headphones")
end

step :select_product do |ctx|
choice = ctx.message.text

```
case choice
when "1"
  ctx.session[:product] = "Phone"
  ctx.scene_data[:next_step] = :ask_quantity
when "2"
  ctx.session[:product] = "Laptop"
  ctx.scene_data[:next_step] = :ask_quantity
when "3"
  ctx.session[:product] = "Headphones"
  ctx.scene_data[:next_step] = :ask_quantity
else
  ctx.reply("Invalid choice, try again!")
  # Stay in same step
  ctx.scene_data[:next_step] = :browse
end
```

end

step :ask_quantity do |ctx|
ctx.reply("How many #{ctx.session[:product]}s?")
end

step :confirm do |ctx|
ctx.session[:quantity] = ctx.message.text.to_i
total = ctx.session[:quantity] * 100  # Example price

```
ctx.reply("Order:")
ctx.reply("Product: #{ctx.session[:product]}")
ctx.reply("Quantity: #{ctx.session[:quantity]}")
ctx.reply("Total: $#{total}")

ctx.reply("Confirm? (yes/no)")
```

end

step :process_order do |ctx|
if ctx.message.text.downcase == "yes"
ctx.reply("✅ Order placed!")
# Process order...
ctx.leave_scene
else
ctx.reply("Order cancelled.")
ctx.leave_scene
end
end
end
)

10). Manual Step Control

-code(

Jump to specific step

ctx.current_scene.process_step(ctx, :ask_email)

Reset to first step

ctx.current_scene.reset(ctx)

Check current step

if ctx.current_scene.current_step(ctx) == :waiting_payment
ctx.reply("Still waiting for payment...")
end
)

🎨 ADVANCED PATTERNS

11). Scene with Timeouts

-code(
bot.scene(:verification) do
on_enter do |ctx|
# Send verification code
code = rand(1000..9999)
ctx.session[:verify_code] = code
ctx.session[:attempts] = 0
ctx.session[:start_time] = Time.now

```
ctx.reply("Your code: #{code} (expires in 5 minutes)")
```

end

step :wait_for_code do |ctx|
# Check timeout
if Time.now - ctx.session[:start_time] > 300  # 5 minutes
ctx.reply("⏰ Code expired!")
ctx.leave_scene
return
end

```
# Check attempts
if ctx.session[:attempts] >= 3
  ctx.reply("🚫 Too many attempts!")
  ctx.leave_scene
  return
end

# Verify code
if ctx.message.text == ctx.session[:verify_code].to_s
  ctx.reply("✅ Verified!")
  ctx.leave_scene
else
  ctx.session[:attempts] += 1
  remaining = 3 - ctx.session[:attempts]
  ctx.reply("❌ Wrong code! #{remaining} attempts left")
  # Stay in same step
end
```

end
end
)

12). Nested Scenes (Scene within Scene)

-code(
bot.scene(:main_menu) do
step :show_menu do |ctx|
keyboard = ctx.inline_keyboard do
row { button "Profile", callback_data: "profile" }
row { button "Settings", callback_data: "settings" }
row { button "Help", callback_data: "help" }
end
ctx.reply("Main Menu:", reply_markup: keyboard)
end

step :handle_choice do |ctx|
case ctx.data
when "profile"
# Enter profile scene but remember to come back
ctx.scene_data[:return_to] = :main_menu
ctx.enter_scene(:profile)
when "settings"
ctx.scene_data[:return_to] = :main_menu
ctx.enter_scene(:settings)
when "help"
ctx.reply("Help information...")
ctx.current_scene.process_step(ctx, :show_menu)
end
end
end

bot.scene(:profile) do
step :show_profile do |ctx|
ctx.reply("Your profile...")
ctx.reply("[Back to menu]")
end

step :handle_back do |ctx|
if ctx.message.text&.include?("back")
# Return to main menu
return_to = ctx.scene_data[:return_to] || :main_menu
ctx.enter_scene(return_to)
end
end
end
)

