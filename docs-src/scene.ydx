15). E-commerce Checkout Scene

-code(
bot.scene(:checkout) do
on_enter do |ctx|
ctx.session[:cart] ||= []
ctx.reply("🛒 Checkout Process")
end

step :select_shipping do |ctx|
keyboard = ctx.keyboard do
row "Standard (3-5 days)"
row "Express (1-2 days)"
row "Overnight"
end
ctx.reply("Select shipping:", reply_markup: keyboard)
end

step :enter_address do |ctx|
ctx.session[:shipping] = ctx.message.text
ctx.reply("Enter your shipping address:")
end

step :select_payment do |ctx|
ctx.session[:address] = ctx.message.text
keyboard = ctx.inline_keyboard do
row { button "💳 Credit Card", callback_data: "cc" }
row { button "📱 Mobile Money", callback_data: "momo" }
row { button "💰 Cash on Delivery", callback_data: "cod" }
end
ctx.reply("Payment method:", reply_markup: keyboard)
end

step :process_payment do |ctx|
ctx.session[:payment] = ctx.data

```
# Simulate payment processing
ctx.reply("Processing payment...")
sleep 2

if ctx.session[:payment] == "cod"
  ctx.reply("✅ Order confirmed! Pay on delivery.")
else
  ctx.reply("✅ Payment successful! Order confirmed.")
end

# Generate order summary
total = calculate_total(ctx.session[:cart])
ctx.reply("Order #: #{rand(100000..999999)}")
ctx.reply("Total: $#{total}")
ctx.reply("Shipping: #{ctx.session[:shipping]}")
ctx.reply("Address: #{ctx.session[:address]}")

ctx.leave_scene
```

end

on_leave do |ctx|
# Clear cart after checkout
ctx.session.delete(:cart)
ctx.reply("Thank you for your order! 📦")
end
end
)

