🔧 ADVANCED PATTERNS

Dependency Injection

```ruby
class BotFactory
  def initialize(database:, analytics:, cache:)
    @services = { db: database, analytics: analytics, cache: cache }
  end
  
  def create_bot(token)
    bot = Telegem.new(token)
    
    # Inject services into context
    bot.use do |ctx, next|
      ctx.state[:services] = @services
      next.call(ctx)
    end
    
    bot
  end
end
```

Command Composition

```ruby
module CommandMacros
  def admin_only(&block)
    ->(ctx) do
      if ctx.from.id == ADMIN_ID
        block.call(ctx)
      else
        ctx.reply("Access denied")
      end
    end
  end
  
  def with_retry(max_attempts: 3, &block)
    ->(ctx) do
      attempts = 0
      begin
        block.call(ctx)
      rescue => e
        attempts += 1
        retry if attempts < max_attempts
        raise
      end
    end
  end
end

# Usage
bot.command('admin', &admin_only { |ctx| ctx.reply("Admin stuff") })
```

Event Sourcing Scenes

```ruby
class EventSourcedScene
  def initialize(event_store)
    @event_store = event_store
  end
  
  def call(bot)
    bot.scene(:checkout) do
      step :start do |ctx|
        @event_store.record(ctx.user_id, :checkout_started)
        ctx.reply("Starting checkout...")
      end
      
      step :complete do |ctx|
        @event_store.record(ctx.user_id, :checkout_completed, 
          data: ctx.session.slice(:items, :total))
        ctx.leave_scene
      end
    end
  end
end
```

🧪 TESTING STRATEGY

Unit Testing

```ruby
RSpec.describe MyScene do
  let(:bot) { Telegem.new('test_token') }
  let(:ctx) { instance_double(Telegem::Context, user_id: 123) }
  
  before do
    bot.scene(:test) do
      step :one do |ctx|
        ctx.reply("Step one")
      end
    end
  end
  
  it "sends correct message" do
    expect(ctx).to receive(:reply).with("Step one")
    bot.scenes[:test].enter(ctx)
  end
end
```

Integration Testing

```ruby
class BotTestCase < Minitest::Test
  def setup
    @bot = Telegem.new('test_token')
    @update_queue = Queue.new
    
    # Mock Telegram API
    @bot.api.stub(:call!, ->(method, params) {
      @update_queue << { method: method, params: params }
      { 'ok' => true, 'result' => {} }
    })
  end
  
  def test_command_flow
    update = { 'message' => { 'text' => '/start', 'from' => { 'id' => 1 } } }
    @bot.process(update)
    
    # Assert API calls were made
    assert_equal 1, @update_queue.size
    api_call = @update_queue.pop
    assert_equal 'sendMessage', api_call[:method]
  end
end
```

📈 SCALING CONSIDERATIONS

Horizontal Scaling

```yaml
# docker-compose.prod.yml
version: '3.8'
services:
  bot:
    image: mybot:latest
    scale: 4  # Multiple instances
    environment:
      - REDIS_URL=redis://redis:6379/0  # Shared session store
      - DATABASE_URL=postgres://db/bot
    depends_on:
      - redis
      - db
  
  redis:
    image: redis:7-alpine
    command: redis-server --appendonly yes
  
  load_balancer:
    image: nginx:alpine
    ports:
      - "443:443"
    configs:
      - source: nginx.conf
        target: /etc/nginx/nginx.conf
```

Monitoring & Observability

```ruby
# Instrumentation middleware
class MetricsMiddleware
  def initialize(prometheus: Prometheus::Client.registry)
    @requests = prometheus.counter(:bot_requests_total, 'Total requests')
    @duration = prometheus.histogram(:bot_request_duration, 'Request duration')
  end
  
  def call(ctx, next_middleware)
    start_time = Time.now
    @requests.increment(labels: { handler: ctx.update.type })
    
    next_middleware.call(ctx)
    
    duration = Time.now - start_time
    @duration.observe(duration, labels: { handler: ctx.update.type })
  rescue => e
    # Record errors
    @errors.increment(labels: { error: e.class.name })
    raise
  end
end
```

🔄 MIGRATION PATHS

From telegram-bot-ruby

```ruby
# OLD (telegram-bot-ruby)
bot = Telegram::Bot::Client.new(token)
bot.listen do |message|
  case message.text
  when '/start'
    bot.api.send_message(chat_id: message.chat.id, text: 'Hello')
  end
end

# NEW (Telegem)
bot = Telegem.new(token)
bot.command('start') { |ctx| ctx.reply('Hello') }
bot.start_polling

# Changes:
# 1. Handler registration vs message loop
# 2. Context object vs raw message
# 3. Async vs sync API calls
# 4. Middleware pipeline vs manual filtering
```

From plain HTTP clients

```ruby
# OLD (DIY)
response = HTTParty.post(
  "https://api.telegram.org/bot#{token}/sendMessage",
  body: { chat_id: chat_id, text: 'Hello' }.to_json
)

# NEW (Telegem)
# 1. Get framework benefits for free
# 2. Focus on business logic
# 3. Built-in error handling, retries, rate limiting
```

🎯 DECISION FRAMEWORK

When to Choose Telegem

✅ Choose Telegem when:

· High message volume (>100 msg/sec)
· Complex conversation flows needed
· Existing Telegraf.js knowledge on team
· Async I/O patterns already in codebase
· Need production-grade session persistence
· Planning for horizontal scaling

❌ Consider alternatives when:

· Simple bot with <10 commands
· Team unfamiliar with async patterns
· Tight integration with synchronous Rails app
· Minimal dependencies requirement
· Debugging simplicity is top priority

Feature Comparison Matrix

Feature Telegem telegram-bot-ruby grammarbot
Async I/O ✅ Full ❌ None ❌ None
Middleware ✅ Full pipeline ❌ Manual ❌ None
Scene System ✅ Complete ❌ None ❌ None
Session Stores ✅ Multiple ✅ Basic ❌ None
Type Safety ✅ Strong ⚠️ Partial ❌ None
Performance 🟢 High 🟡 Medium 🔴 Low
Learning Curve 🟡 Moderate 🟢 Low 🟢 Very Low
Production Ready ✅ Yes ✅ Yes ❌ No

---

Telegem is a production-ready, async-first framework for building scalable Telegram bots in Ruby. It excels at complex conversation flows, high-volume applications, and teams familiar with modern async patterns. The learning curve pays dividends in maintainability and performance at scale.

-note(Complete API reference available in docs/ folder)
-warning(Async programming requires understanding of fiber scheduling and cooperative multitasking)
